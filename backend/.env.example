# ─────────────────────────────────────────────────────────────
#  VoteSarthi Backend — Environment Variables Template
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────

# Google OAuth Client ID (for verifying Google ID tokens server-side)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Google Maps Embed API Key (used server-side only to build embed URLs)
# Restrict this key in Google Cloud Console to the Maps Embed API only.
GOOGLE_MAPS_API_KEY=your-google-maps-embed-api-key

# AI Provider — Google Gemini (required for AI features)
GEMINI_API_KEY=your-gemini-api-key
